# Tori — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://app:password@localhost:5432/subscriptions_engine

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string (required)
REDIS_URL=redis://localhost:6379

# ── Nomba (required for live payments) ────────────────────────────────────────
# Live credentials — hits api.nomba.com
NOMBA_CLIENT_ID=your_live_client_id
NOMBA_CLIENT_SECRET=your_live_client_secret
NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
NOMBA_ENV=production

# Sandbox credentials — hits sandbox.nomba.com (used by tori_test_ keys)
NOMBA_TEST_CLIENT_ID=your_sandbox_client_id
NOMBA_TEST_CLIENT_SECRET=your_sandbox_client_secret

# Nomba inbound webhook secret — used to verify payment_success signatures
# If unset, webhook verification is skipped (fail-open). Always set in production.
NOMBA_WEBHOOK_SECRET=your_nomba_webhook_secret

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — minimum 32 characters (required)
JWT_SECRET=your_jwt_secret_minimum_32_chars

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Resend API key — used for email verification, welcome, and invite emails
# (sent by the API service) AND merchant billing emails: subscription
# activated, payment succeeded/failed, dunning, trial-ending-soon (sent by
# the WORKER service). Required on BOTH services when deployed separately
# (e.g. Railway) — locally docker-compose shares one .env file so this is
# easy to miss until a production deploy where each service has its own
# environment. Without it, ResendClient silently no-ops and logs
# "email: [DEV MODE — not sent]" instead of sending.
# Get one at https://resend.com
RESEND_API_KEY=re_your_resend_api_key

# ── Frontend ──────────────────────────────────────────────────────────────────
# The public URL of the frontend — used in invite email links (required)
APP_URL=http://localhost:3001

# The public URL of the API — used by the frontend to make requests (required)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── API Server ────────────────────────────────────────────────────────────────
# Port the API listens on (optional, default: 8080)
PORT=8080

# ── Worker ────────────────────────────────────────────────────────────────────
# Worker uses DATABASE_URL and REDIS_URL above.
# No additional env vars required for the worker.

# ── Seed script (optional) ────────────────────────────────────────────────────
# Override the default seed tenant credentials
SEED_TENANT_EMAIL=dev@tori.ng
SEED_TENANT_PASSWORD=tori-dev-2026
SEED_TENANT_NAME=ClassPay
