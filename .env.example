# =============================================================================
# Tori — Subscriptions & Recurring Billing Engine
# Environment Variables Reference
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=subscriptions_engine
DB_USER=app
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgres://app:change_me_in_production@postgres:5432/subscriptions_engine?sslmode=disable

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_PORT=8080
API_ENV=development
# development | production

# -----------------------------------------------------------------------------
# JWT — Dashboard & Tenant Auth
# Use a minimum 256-bit random secret. Generate with:
# openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_32_byte_hex_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# JWT — Admin API (separate signing key, shorter expiry)
# -----------------------------------------------------------------------------
ADMIN_JWT_SECRET=replace_with_different_32_byte_hex_secret
ADMIN_JWT_EXPIRY=1h

# -----------------------------------------------------------------------------
# Nomba Payment Integration
# Obtain from your Nomba developer dashboard.
# Never log these values. Never include in error messages.
# -----------------------------------------------------------------------------
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_CLIENT_ID=replace_with_nomba_client_id
NOMBA_CLIENT_SECRET=replace_with_nomba_client_secret
NOMBA_WEBHOOK_SECRET=replace_with_nomba_webhook_secret
NOMBA_ACCOUNT_ID=replace_with_nomba_account_id

# -----------------------------------------------------------------------------
# Worker Process
# -----------------------------------------------------------------------------
WORKER_POLL_INTERVAL=10s
WORKER_STALE_LOCK_THRESHOLD=10m
WORKER_INSTANCE_ID=worker-1
# Override per instance in multi-worker deployments

# -----------------------------------------------------------------------------
# Rate Limiting (default per tenant — overridable via dunning_config)
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Portal Token
# -----------------------------------------------------------------------------
PORTAL_TOKEN_EXPIRY=1h

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# debug | info | warn | error
